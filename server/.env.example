# CORS Configuration
# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-frontend.onrender.com,https://backup.onrender.com

# Allow all Render domains (set to 'true' for flexibility)
ALLOW_RENDER_DOMAINS=true

# Environment
NODE_ENV=production

# Game Configuration
TURN_TIME_LIMIT=10
STALE_CONNECTION_TIMEOUT=300000

# Development example:
# CORS_ORIGINS=http://localhost:5173,http://localhost:3001
# ALLOW_RENDER_DOMAINS=false
# NODE_ENV=development
